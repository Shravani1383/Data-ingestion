3. CORE LANGGRAPH STATE

This is the MOST IMPORTANT PART.

Your whole graph runs using shared state.

GraphState

from typing import TypedDict, List, Dict, Set, Optional

class GraphState(TypedDict):

    # user input
    user_query: str

    # routing
    mode: str

    # extracted URLs
    urls: List[str]

    # retrieval
    generated_cql: Optional[str]

    search_results: List[dict]

    reranked_results: List[dict]

    # fetched pages
    fetched_pages: Dict[str, dict]

    # traversal
    pending_urls: List[str]

    visited_urls: List[str]

    recursion_depth: int

    # compressed chunks
    context_chunks: List[str]

    compressed_context: str

    # budgets
    token_budget_remaining: int

    pages_fetched: int

    # final
    final_answer: str


